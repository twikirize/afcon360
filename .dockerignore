# =============================================================================
# AFCON360 — .dockerignore
# Prevents secrets, dev files, and build artifacts from entering the image
# =============================================================================

# Environment files — NEVER bake secrets into the image
.env
.env.local
.env.docker
.env.prod
.env.*

# Git
.git
.gitignore
.gitattributes

# Python cache & build artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# Test & coverage
.pytest_cache/
.coverage
htmlcov/
tests/

# Logs
logs/
*.log

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Docker files (don't nest Dockerfiles inside image)
Dockerfile*
docker-compose*.yml
docker/

# Migrations backup
migrations/versions/*.pyc

# Node (if any frontend tooling)
node_modules/
npm-debug.log

# Misc
*.md
README*
CHANGELOG*
