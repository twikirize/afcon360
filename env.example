# AFCON360 Production Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# SECURITY KEYS (REQUIRED)
# =============================================================================
SECRET_KEY=your-super-secret-key-here-min-32-chars
ENCRYPTION_KEY=your-encryption-key-here-min-32-chars
MFA_ENCRYPTION_KEY=your-mfa-encryption-key-here-min-32-chars

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=afcon360_prod
DB_USER=postgres
DB_PASS=your-secure-database-password

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_DIR=/var/backups/afcon360
S3_BUCKET=your-backup-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# =============================================================================
# PAYMENT PROVIDERS
# =============================================================================
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=AFCON360 <noreply@afcon360.com>

# =============================================================================
# SMS PROVIDER
# =============================================================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# MONITORING
# =============================================================================
GRAFANA_PASSWORD=your-grafana-password
PROMETHEUS_URL=http://localhost:9090

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
FLASK_ENV=production
DEBUG=false
REQUIRE_OWNER_MFA=true
SESSION_TIMEOUT_MINUTES=30

# =============================================================================
# WALLET SETTINGS
# =============================================================================
WALLET_ENABLED=true
MAX_TRANSACTION_AMOUNT=10000000
DAILY_TRANSACTION_LIMIT=50000000

# =============================================================================
# COMPLIANCE SETTINGS
# =============================================================================
AML_ENABLED=true
KYC_REQUIRED=true
TRAVEL_RULE_ENABLED=true
COMPLIANCE_EMAIL=compliance@afcon360.com

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/afcon360.log

# =============================================================================
# ENHANCED SECURITY SETTINGS
# =============================================================================
# MFA Settings
MFA_BACKUP_CODES_COUNT=10
MFA_TOTP_WINDOW=1

# KYC Settings
KYC_ENHANCED_RISK_ASSESSMENT=true
KYC_EXPIRY_WARNING_DAYS=30
KYC_AUTO_EXPIRY_CHECK=true

# Session Management
SESSION_ROTATION_MINUTES=15
SESSION_INTEGRITY_CHECK=true

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_HISTORY_COUNT=5
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true